# AtomicNet environment template. Copy to `.env` (which is git-ignored) and fill in.
#   cp .env.example .env

# --- AI treasury agent (Stage 4) ---
# Get a key at https://console.anthropic.com/ . Never commit the real value.
ANTHROPIC_API_KEY=
# Latest capable model for the agent (proposal + rationale).
ANTHROPIC_MODEL=claude-opus-4-8

# --- Ledger connection (dpm sandbox defaults) ---
LEDGER_HOST=localhost
LEDGER_PORT=6865
JSON_API_URL=http://localhost:7575
