# AtomicNet environment template. Copy to `.env` (which is git-ignored) and fill in.
#   cp .env.example .env

# --- Ledger / backend ---
JSON_API_URL=http://localhost:7575
PORT=8080

# --- AI treasury agent (OpenAI-compatible chat-completions endpoint) ---
# Works with any OpenAI-compatible provider (MiMo, OpenAI, Anthropic-compat gateways).
# Never commit the real key.
AGENT_API_KEY=
AGENT_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
AGENT_MODEL=mimo-v2.5-pro
