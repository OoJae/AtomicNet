# AtomicNet environment template. Copy to `.env` (which is git-ignored) and fill in.
#   cp .env.example .env

# --- Ledger / backend ---
JSON_API_URL=http://localhost:7575
PORT=8080

# --- Shared/remote validator (e.g. hackathon DevNet validator) — all optional ---
# JSON_API_HOST_HEADER=json-ledger-api.localhost   # if the endpoint routes on Host
# LEDGER_API_TOKEN=                                # static Bearer (short demos only)
# LEDGER_OAUTH_TOKEN_URL=                          # OAuth2 client-credentials (auto-refresh)
# LEDGER_OAUTH_CLIENT_ID=
# LEDGER_OAUTH_CLIENT_SECRET=
# LEDGER_OAUTH_SCOPE=daml_ledger_api
# PARTY_HINT_PREFIX=atomicnet-                     # team-prefixed party hints on shared participants
# PARTY_HINT_SUFFIX=-1

# --- AI treasury agent (OpenAI-compatible chat-completions endpoint) ---
# Works with any OpenAI-compatible provider (MiMo, OpenAI, Anthropic-compat gateways).
# Never commit the real key.
AGENT_API_KEY=
AGENT_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
AGENT_MODEL=mimo-v2.5-pro
